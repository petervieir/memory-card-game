# Required: Your Hiro Platform API key
# Get this from https://platform.hiro.so/settings/api-keys
NEXT_PUBLIC_PLATFORM_HIRO_API_KEY=your-api-key-here

# Stacks Deployment Configuration (for contract deployment)
# Required: Your Stacks private key (64-character hex string)
STACKS_PRIVATE_KEY=your_private_key_here

# Optional: Custom API URLs (defaults to official Hiro endpoints)
STACKS_API_URL_TESTNET=https://api.testnet.hiro.so
STACKS_API_URL_MAINNET=https://api.mainnet.hiro.so

# Optional: Deployment environment
NODE_ENV=development

# Optional: Contract deployment settings
CONTRACT_NAME=memory-game
DEPLOY_TIMEOUT=60000

# Optional: Gas settings (will use estimation if not provided)
# MAX_FEE_RATE=1000 